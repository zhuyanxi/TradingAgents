# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Data Vendor API Keys
# Required only when data_vendors is set to "alpha_vantage"
ALPHA_VANTAGE_API_KEY=

# Application Settings
# Directory where analysis results are saved
TRADINGAGENTS_RESULTS_DIR=./results

# Redis (optional – only needed if using Redis-backed memory)
# When using docker-compose, this points to the redis service
REDIS_URL=redis://redis:6379/0