FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Install system deps
RUN apt-get update && apt-get install -y --no-install-recommends gcc \
    && rm -rf /var/lib/apt/lists/*

# Install the main project (tradingagents + cli packages) first
COPY pyproject.toml ./
COPY tradingagents/ tradingagents/
COPY cli/ cli/
RUN pip install --upgrade pip && pip install -e .

# Install webui backend extras
COPY webui/requirements.txt webui/requirements.txt
RUN pip install -r webui/requirements.txt

# Copy the rest (for .env loading)
COPY .env* ./

EXPOSE 8000
CMD ["uvicorn", "webui.backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
